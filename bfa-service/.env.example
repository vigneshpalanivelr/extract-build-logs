# Build Failure Analyzer (BFA) Service Configuration
# Copy this file to .env and fill in the required values.

# ============================================================================
# REQUIRED SETTINGS
# ============================================================================

# Slack bot token (xoxb-...) for posting messages and handling actions
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack channel ID where BFA posts fix suggestions
SLACK_CHANNEL=C0123456789

# OpenWebUI API key for LLM calls
OPENWEBUI_API_KEY=your-openwebui-api-key

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection URL (used by analyzer_service.py)
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# Redis host/port/db (used by slack_helper.py)
# Default: localhost / 6379 / 0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================================================
# LLM / OPENWEBUI CONFIGURATION
# ============================================================================

# OpenWebUI base URL (no trailing slash)
# Default: https://chat-internal.com
OPENWEBUI_BASE_URL=https://chat-internal.com

# LLM model identifier
# Default: anthropic.claude-sonnet-4-20250514-v1:0
OPENWEBUI_MODEL=anthropic.claude-sonnet-4-20250514-v1:0

# Request timeout in seconds for LLM calls
# Default: 60
OPENWEBUI_TIMEOUT=60

# Number of retries for failed LLM requests
# Default: 2
OPENWEBUI_RETRIES=2

# Exponential backoff multiplier for LLM retries
# Default: 0.5
OPENWEBUI_BACKOFF=0.5

# Default LLM temperature for generation
# Default: 0.2
LLM_DEFAULT_TEMPERATURE=0.2

# Default max tokens for resolver_agent generation
# Default: 512
LLM_DEFAULT_MAX_TOKENS=512

# Max tokens for analyze_with_llm (rate-my-mr)
# Default: 1024
LLM_ANALYZE_MAX_TOKENS=1024

# ============================================================================
# VECTOR DB (CHROMADB) CONFIGURATION
# ============================================================================

# ChromaDB persistence directory
# Default: /home/build-failure-analyzer/data/chroma
CHROMA_DB_PATH=/var/lib/redis/bfa-data

# ChromaDB collection name for fix embeddings
# Default: fix_embeddings
CHROMA_COLLECTION=fix_embeddings

# ChromaDB collection name for domain context patterns
# Default: pipeline_context
DOMAIN_CONTEXT_COLLECTION=pipeline_context

# Similarity threshold for vector DB matches (0.0 - 1.0)
# Default: 0.78
SIMILARITY_THRESHOLD=0.78

# Max error lines to keep after normalization
# Default: 80
MAX_ERROR_LINES=80

# Max error characters after normalization
# Default: 4000
MAX_ERROR_CHARS=4000

# Length penalty alpha for similarity scoring (higher = stricter)
# Default: 0.15
LENGTH_PENALTY_ALPHA=0.15

# Default vector search top-k results
# Default: 5
VECTOR_TOP_K=5

# ============================================================================
# OLLAMA EMBEDDING CONFIGURATION
# ============================================================================

# Ollama HTTP API URL for embeddings
# Default: http://127.0.0.1:11434
OLLAMA_HTTP_URL=http://127.0.0.1:11434

# Ollama CLI binary path
# Default: ollama
OLLAMA_CLI_PATH=ollama

# Ollama embedding model name
# Default: granite-embedding
OLLAMA_EMBED_MODEL=granite-embedding

# Timeout in seconds for Ollama embedding requests
# Default: 30
OLLAMA_TIMEOUT=30

# ============================================================================
# JWT AUTHENTICATION CONFIGURATION
# ============================================================================

# Path to RSA public key for JWT verification (analyzer_service.py)
# Default: /home/build-failure-analyzer/public.pem
JWT_PUBLIC_KEY_PATH=/home/build-failure-analyzer/public.pem

# Path to RSA private key for JWT signing (jwt_dmz_issuer.py, jwt_sign_helper.py)
# Default: /home/build-failure-analyzer/private.pem
JWT_PRIVATE_KEY_PATH=/home/build-failure-analyzer/private.pem

# JWT audience claim
# Default: build-failure-analyzer
JWT_AUDIENCE=build-failure-analyzer

# JWT issuer claim (used by jwt_dmz_issuer.py)
# Default: dmz-analyzer
JWT_ISSUER=dmz-analyzer

# JWT issuer claim (used by jwt_sign_helper.py)
# Default: corp-ci-system
JWT_ISS=corp-ci-system

# JWT token expiry in minutes (jwt_dmz_issuer.py)
# Default: 60
JWT_EXPIRY_MINUTES=60

# JWT token TTL in seconds (jwt_sign_helper.py)
# Default: 60
JWT_TTL_SECONDS=60

# ============================================================================
# DOMAIN RAG CONFIGURATION
# ============================================================================

# Path to domain context patterns JSON file
# Default: /home/build-failure-analyzer/build-failure-analyzer/context/domain_context_patterns.json
DOMAIN_CONTEXT_PATH=/home/build-failure-analyzer/build-failure-analyzer/context/domain_context_patterns.json

# Similarity threshold for domain RAG matches
# Default: 0.55
DOMAIN_RAG_THRESHOLD=0.55

# Top-K results for domain RAG queries
# Default: 5
DOMAIN_RAG_TOP_K=5

# Path to global infrastructure context document
# Default: /home/build-failure-analyzer/build-failure-analyzer/context/infra_overview.md
GLOBAL_CONTEXT_PATH=/home/build-failure-analyzer/build-failure-analyzer/context/infra_overview.md

# Max characters for global context document
# Default: 6000
GLOBAL_CONTEXT_MAX_CHARS=6000

# ============================================================================
# RESOLVER AGENT CONFIGURATION
# ============================================================================

# Redis TTL for AI-generated fix cache (seconds)
# Default: 86400 (24 hours)
REDIS_TTL_AI=86400

# Redis TTL for AI fix entries in analyzer_service (seconds)
# Default: 86400 (24 hours)
AI_FIX_TTL=86400

# Confidence score assigned to LLM-generated fixes
# Default: 0.6
LLM_GENERATED_CONFIDENCE=0.6

# ============================================================================
# SLACK MESSAGE CONFIGURATION
# ============================================================================

# Max characters per Slack block section
# Default: 2500
SLACK_MAX_BLOCK_LEN=2500

# Max characters for error summary before AI summarization kicks in
# Default: 300
ERROR_SUMMARY_MAX_CHARS=300

# ============================================================================
# ERROR NOTIFICATION CONFIGURATION
# ============================================================================

# Comma-separated Slack user emails for DM alerts on internal errors
# Default: (empty)
ALERT_SLACK_EMAILS=

# Comma-separated email addresses for SMTP alerts
# Default: (empty)
ALERT_EMAIL_TO=

# SMTP server hostname (leave empty to disable email alerts)
# Default: (empty)
SMTP_SERVER=

# SMTP server port
# Default: 25
SMTP_PORT=25

# SMTP sender address
# Default: bfa-alerts@localhost
SMTP_FROM=bfa-alerts@localhost

# SMTP connection timeout in seconds
# Default: 10
SMTP_TIMEOUT=10

# Max characters for traceback in Slack alerts
# Default: 3500
TRACEBACK_MAX_CHARS=3500

# ============================================================================
# SLACK REVIEWER (FLASK) CONFIGURATION
# ============================================================================

# Flask host for Slack reviewer webhook listener
# Default: 0.0.0.0
FLASK_HOST=0.0.0.0

# Flask port for Slack reviewer webhook listener
# Default: 5001
FLASK_PORT=5001

# Enable Flask debug mode
# Options: true, false
# Default: false
FLASK_DEBUG=false

# ============================================================================
# ANALYZER SERVICE CONFIGURATION
# ============================================================================

# FastAPI server host binding
# Default: 0.0.0.0
BFA_HOST=0.0.0.0

# FastAPI server port
# Default: 8000
BFA_PORT=8000

# ============================================================================
# USAGE INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and set your required values (Slack token, OpenWebUI key)
#
# 3. Run the analyzer service:
#    python analyzer_service.py
#
# 4. Run the Slack reviewer (separate process):
#    python slack_reviewer.py
#
# For more information, see README.md
#
# ============================================================================
